APP_SQS_QUEUE=your-sqs-queue-url
WHATSAPP_API_TOKEN=your-whatsapp-api-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
RUNPOD_API_KEY=your-runpod-api-key
RUNPOD_ENDPOINT_ID=your-runpod-endpoint-id
POSTHOG_API_KEY=your-posthog-api-key

# Optional: fleet-wide, persistent /status via the Eliezer Status site. Set STATUS_SITE_URL
# to enable: each instance POSTs per-event metadata to the site, which aggregates the whole
# fleet and renders a live dashboard; /status then reports fleet numbers plus the link. Leave
# unset for single-instance /status (the local windowed view). STATUS_INGEST_TOKEN must match
# the site's INGEST_TOKEN; STATUS_USER_SALT must be identical across instances so the unique-
# user count is consistent fleet-wide. INSTANCE_ID is an optional per-instance label.
# STATUS_SITE_URL=https://eliezer-status-youruser.xhostd.com
# STATUS_INGEST_TOKEN=your-shared-ingest-token
# STATUS_USER_SALT=your-shared-salt
# INSTANCE_ID=primary

